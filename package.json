{
  "name": "evorupa",
  "version": "0.1.0",
  "description": "Infrastructure reporting PWA for Serbia - Citizen-driven road and infrastructure issue mapping",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "node scripts/build-cloudflare.js",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "supabase:apply-schema": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-schema.ps1",
    "supabase:apply-settlements": "powershell -ExecutionPolicy Bypass -File scripts/apply-serbia-settlements.ps1",
    "supabase:build-settlements": "powershell -ExecutionPolicy Bypass -File scripts/build-serbia-settlements.ps1",
    "supabase:export-settlements-sql": "node scripts/export-settlements-sql.js",
    "supabase:import-settlements": "powershell -ExecutionPolicy Bypass -File scripts/import-settlements-json.ps1",
    "seed:test-serbia": "node scripts/seed-serbia-test-data.js",
    "deploy:cf": "npm run build:cf && npx wrangler pages deploy .vercel/output/static --project-name evorupa",
    "sync:cf:secrets": "powershell -ExecutionPolicy Bypass -File scripts/sync-cloudflare-secrets.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.6.0",
    "leaflet": "^1.9.0",
    "mapbox-gl": "^2.15.0",
    "next": "15.5.2",
    "next-pwa": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.0",
    "react-map-gl": "^7.1.0",
    "sharp": "^0.35.3",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.14",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.2",
    "pg": "^8.13.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.114.14"
  }
}
