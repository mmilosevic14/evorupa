{
  "name": "evorupa",
  "version": "0.1.0",
  "description": "Infrastructure reporting PWA for Serbia - Citizen-driven road and infrastructure issue mapping",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run test",
    "build": "next build",
    "build:cf": "node scripts/build-cloudflare.js",
    "build:pages": "npm run build:cf && node scripts/prepare-pages-deploy.js",
    "preview:cf": "npm run build:cf && npx opennextjs-cloudflare preview --config wrangler.worker.toml",
    "preview:pages": "npm run build:pages && npx wrangler pages dev .pages-deploy",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "generate:og": "node scripts/generate-og-image.js",
    "generate:brand-assets": "node scripts/generate-og-image.js",
    "supabase:apply-schema": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-schema.ps1",
    "supabase:apply-settlements": "powershell -ExecutionPolicy Bypass -File scripts/apply-serbia-settlements.ps1",
    "supabase:build-settlements": "powershell -ExecutionPolicy Bypass -File scripts/build-serbia-settlements.ps1",
    "supabase:export-settlements-sql": "node scripts/export-settlements-sql.js",
    "supabase:import-settlements": "powershell -ExecutionPolicy Bypass -File scripts/import-settlements-json.ps1",
    "seed:test-serbia": "node scripts/seed-serbia-test-data.js",
    "deploy:cf": "npm run deploy:pages",
    "deploy:pages": "npm run build:pages && npx wrangler pages deploy .pages-deploy --project-name evorupa",
    "deploy:worker": "npm run build:cf && npx opennextjs-cloudflare deploy --config wrangler.worker.toml",
    "sync:cf:secrets": "powershell -ExecutionPolicy Bypass -File scripts/sync-cloudflare-secrets.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.6.0",
    "leaflet": "^1.9.0",
    "mapbox-gl": "^2.15.0",
    "next": "15.5.20",
    "next-pwa": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.0",
    "react-map-gl": "^7.1.0",
    "sharp": "^0.35.3",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.0",
    "esbuild": "0.25.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "pg": "^8.13.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
